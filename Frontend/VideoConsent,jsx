import React, { useState, useEffect, useRef } from 'react';
// Import the Twilio Video SDK for WebRTC communication
import Video from 'twilio-video'; 

const VideoConsent = () => {
  const [isConsentGranted, setIsConsentGranted] = useState(false);
  const [loading, setLoading] = useState(false);
  
  // Reference to the DOM element where the local camera feed will be injected
  const localVideoRef = useRef(null); 

  // Step 1: Handle the patient's consent submission
  const handleConsentAccept = async () => {
    setLoading(true);
    try {
      // Send a POST request to the backend to record the consent securely
      const response = await fetch('http://localhost:5000/api/appointments/123/consent', {
        method: 'POST',
      });
      
      // If the backend successfully updates the database, unlock the video room
      if (response.ok) {
        setIsConsentGranted(true);
      }
    } catch (error) {
      console.error("Error recording consent:", error);
      alert("Unable to connect to the backend. Please ensure the Node.js server is running.");
    } finally {
      setLoading(false);
    }
  };

  // Step 2: Request Twilio access token and initialize the camera once consent is granted
  useEffect(() => {
    if (isConsentGranted) {
      // Fetch a secure JWT video token from our Node.js backend
      fetch('http://localhost:5000/api/video/token')
        .then(res => res.json())
        .then(data => {
          if(data.token) {
            // Request hardware access to the user's camera and microphone
            Video.createLocalVideoTrack().then(track => {
              // Attach the live media track to our referenced UI container
              if (localVideoRef.current) {
                localVideoRef.current.appendChild(track.attach());
              }
            });
          } else {
            console.error("Token retrieval failed. Please verify Twilio environment variables.");
          }
        })
        .catch(err => console.error("Video streaming error:", err));
    }
  }, [isConsentGranted]); // This effect triggers only when the consent state changes

  // Render the Active Video Room UI if the patient has agreed to the terms
  if (isConsentGranted) {
    return (
      <div style={{ textAlign: 'center', padding: '50px' }}>
        <h2>🎥 Live Video Consultation Room</h2>
        <p>Connecting to Dr. Nitin...</p>
        
        {/* Container for the live camera feed attached via the useRef hook */}
        <div 
          ref={localVideoRef} 
          style={{ width: '600px', height: '400px', background: '#222', margin: '0 auto', borderRadius: '10px', overflow: 'hidden', border: '3px solid #4CAF50' }}
        >
        </div>

      </div>
    );
  }

  // Render the Waiting Room / Consent Gatekeeper if consent is pending
  return (
    <div style={{ padding: '40px', maxWidth: '600px', margin: '0 auto', fontFamily: 'sans-serif' }}>
      <h2>Waiting Room</h2>
      <div style={{ border: '1px solid #ccc', padding: '20px', borderRadius: '8px', background: '#f9f9f9', boxShadow: '0 4px 8px rgba(0,0,0,0.1)' }}>
        <h3>Patient Consent Required</h3>
        <p>Before initiating the video call, please review the following:</p>
        <ul>
          <li>This call will be encrypted end-to-end to protect your medical privacy.</li>
          <li>Your audio and video will be shared with the consulting doctor.</li>
          <li>A digital record of your consent will be stored in our secure database.</li>
        </ul>
        <p>Do you agree to proceed with the video consultation?</p>
        
        <button 
          onClick={handleConsentAccept} 
          disabled={loading}
          style={{ background: '#4CAF50', color: 'white', padding: '12px 24px', border: 'none', borderRadius: '5px', cursor: 'pointer', marginRight: '10px', fontWeight: 'bold' }}
        >
          {loading ? "Recording Status..." : "I Agree - Join Call"}
        </button>
      </div>
    </div>
  );
};

export default VideoConsent;
